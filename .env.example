# Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# SStats.net API
SSTATS_API_KEY=your_key_here
SSTATS_API_HOST=https://api.sstats.net

# Database
DATABASE_URL=postgresql://capper:capper@localhost:5432/capper
POSTGRES_USER=capper
POSTGRES_PASSWORD=capper
POSTGRES_DB=capper

# pgAdmin
PGADMIN_EMAIL=admin@capper.com
PGADMIN_PASSWORD=admin

# App
ENV=development  # development | production
